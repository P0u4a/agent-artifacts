{
  "name": "@p0u4a/agent-artifacts",
  "version": "0.0.1",
  "description": "Agent-authored MDX artifacts for Codex, Claude Code, and Pi.",
  "type": "module",
  "bin": {
    "agent-artifacts": "./dist/cli/index.js"
  },
  "exports": {
    ".": "./dist/index.js",
    "./compiler": "./dist/compiler/index.js",
    "./runtime": "./dist/runtime/index.js"
  },
  "files": [
    "dist",
    "skills"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && tailwindcss -i src/runtime/styles.css -o dist/runtime/globals.css --minify && node scripts/copy-assets.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "keywords": [
    "agent-skills",
    "pi-package",
    "artifacts",
    "mdx"
  ],
  "pi": {
    "skills": [
      "./skills/artifact"
    ]
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@mdx-js/mdx": "^3.1.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "embla-carousel-react": "^8.6.0",
    "esbuild": "^0.28.1",
    "lucide-react": "^1.23.0",
    "mermaid": "^11.16.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-resizable-panels": "^4.12.0",
    "recharts": "^3.8.0",
    "rehype-pretty-code": "^0.14.3",
    "remark-gfm": "^4.0.1",
    "remark-mdx": "^3.1.1",
    "remark-parse": "^11.0.0",
    "shiki": "^4.3.1",
    "tailwind-merge": "^3.6.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.2",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "~6.0.0"
  }
}